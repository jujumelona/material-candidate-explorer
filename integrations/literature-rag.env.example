# OpenAI-compatible RAG planner / evidence extractor
RAG_MODEL_API_URL=https://YOUR-ENDPOINT/v1
RAG_MODEL_NAME=YOUR-MODEL
RAG_MODEL_API_KEY=
RAG_MODEL_TIMEOUT_SECONDS=180

# Scholarly API identity / optional keys
LITERATURE_CONTACT_EMAIL=researcher@example.com
NCBI_API_KEY=
OPENALEX_API_KEY=
LITERATURE_USER_AGENT=DiscoveryOS/0.4 researcher@example.com

# Optional MCP Streamable HTTP evidence tool (stable 2025-11-25 protocol)
# Tool result: {"records": [{"source_id", "title", ...}]}
MATERIAL_RAG_MCP_URL=https://YOUR-MCP-SERVER/mcp
MATERIAL_RAG_MCP_TOOL=search_material_evidence
MATERIAL_RAG_MCP_TOKEN=
MATERIAL_RAG_MCP_TIMEOUT_SECONDS=60
MATERIAL_RAG_MCP_ALLOW_LOOPBACK_HTTP=0
